{
  "servers": {
    "ezer-main": { "ip": "100.102.25.109", "user": "root" },
    "ezer-static-001": { "ip": "100.106.226.53", "user": "root" },
    "ezer-jho": { "ip": "100.110.228.58", "user": "root" }
  },
  "commands": {
    "SSH": {
      "template": "ssh {user}@{ip}"
    },
    "Tunnel": {
      "template": "ssh -L {local}:localhost:{remote} {user}@{ip}",
      "args": [
        { "id": "local", "prompt": "Local Port", "default": "8080" },
        { "id": "remote", "prompt": "Remote Port", "default": "80" }
      ]
    },
    "System Maintenance": {
      "template": "run_remote.sh -i {ip} -f system_maintenance.sh"
    },
    "Dist Upgrade": {
      "template": "run_remote.sh -i {ip} -f dist_upgrade.sh"
    },
    "Upload File": {
      "template": "scp {file} {user}@{ip}:{dest}",
      "args": [
        {
          "id": "file",
          "prompt": "Local File Name/Path",
          "default": "example.txt"
        },
        {
          "id": "dest",
          "prompt": "Remote Destination Path",
          "default": "~/"
        }
      ]
    },
    "Download File": {
      "template": "scp {user}@{ip}:{remote_path} {local_path}",
      "args": [
        {
          "id": "remote_path",
          "prompt": "Remote File Path",
          "default": "/home/{user}/file.txt"
        },
        {
          "id": "local_path",
          "prompt": "Local Destination (path or .)",
          "default": "."
        }
      ]
    },
    "Restart Server": {
      "template": "run_remote.sh -i {ip} -f reboot.sh"
    }
  }
}
